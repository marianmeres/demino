{
  "name": "@marianmeres/demino",
  "version": "1.16.0",
  "exports": "./src/mod.ts",
  "tasks": {
    "dev": "deno run --watch ./src/mod.ts",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "rp": "deno task release -y && deno publish",
    "rpm": "deno task release minor -y && deno publish"
  },
  "imports": {
    "@marianmeres/clog": "jsr:@marianmeres/clog@^3.21.0",
    "@marianmeres/http-utils": "jsr:@marianmeres/http-utils@^2.11.0",
    "@marianmeres/midware": "jsr:@marianmeres/midware@^1.5.0",
    "@marianmeres/simple-router": "jsr:@marianmeres/simple-router@^3.4.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/http": "jsr:@std/http@^1.1.1",
    "@std/path": "jsr:@std/path@^1.1.5",
    "request-ip": "npm:request-ip@^3.3.0",
    "@marianmeres/mcp-server/types": "jsr:@marianmeres/mcp-server@^1.3.2/types"
  },
  "publish": {
    "exclude": [
      ".*",
      "tests/**"
    ]
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4
  }
}
